{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "go: build",
      "type": "shell",
      "command": "make build",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$go"]
    },
    {
      "label": "go: run",
      "type": "shell",
      "command": "make run",
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "go: test",
      "type": "shell",
      "command": "go test ./...",
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": ["$go"]
    },
    {
      "label": "go: lint (golangci-lint)",
      "type": "shell",
      "command": "make lint",
      "problemMatcher": ["$go"]
    }
  ]
}
